# Backup agent — подключение к Railway-порталу

# URL портала. Используется production-домен Railway.
# В dev-режиме (когда сервер запущен локально): http://localhost:5000
SERVER_URL=https://clodv4-production.up.railway.app

# Тот же ключ что задан в Railway Variables и в server/.env
BACKUP_API_KEY=paste-the-same-key-here

# Корень проекта. Обычно можно оставить пустым — агент возьмёт свой ../.
# Указывай явно только если backup-agent лежит где-то отдельно.
# PROJECT_ROOT=C:\Users\Stepa\Desktop\Harvest scale\ClodV4
