# URL сервера (Railway или локальный)
SERVER_URL=https://your-app.railway.app

# API ключ для авторизации весов (должен совпадать с SCALE_API_KEY на сервере)
SCALE_API_KEY=your-secret-key-here

# Serial порт весов (Ohaus R31P3 через RS-232 → USB адаптер)
# ВАЖНО: использовать стабильный путь /dev/serial/by-id/... , а не /dev/ttyUSBN —
# последние меняются между ребутами и при наличии других USB-serial устройств
# (например Sonoff Zigbee dongle на том же Pi). См. PI_USB_DEVICES.md.
# На текущей ферме: SERIAL_PORT=/dev/serial/by-id/usb-Prolific_Technology_Inc._USB-Serial_Controller_DICGg146B12-if00-port0
SERIAL_PORT=/dev/serial/by-id/usb-Prolific_Technology_Inc._USB-Serial_Controller_XXXXXXX-if00-port0

# Скорость serial порта (9600 — стандарт для Ohaus Ranger 3000)
BAUD_RATE=9600

# Интервал чтения в секундах (0.05 = 20 раз в секунду)
READ_INTERVAL=0.05

# Режим работы:
#   continuous — CP + IP polling: CP для потока стабильных, IP для нестабильных показаний
#   auto       — использовать Auto Print (весы шлют данные только при стабилизации)
SCALE_MODE=continuous

# Сканер штрихкодов (Honeywell Voyager XP 1470)
# Оставить пустым для автоопределения (ищет "Honeywell" в /dev/input/)
# Или указать явно, напр. /dev/input/event2
BARCODE_DEVICE=
